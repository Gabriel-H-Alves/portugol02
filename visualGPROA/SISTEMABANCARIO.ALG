Algoritmo "SistemaBancario"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Jailson Costa do Santos
// Descriçăo   : Sistema Bancario
// Autor(a)    : Gabriel Henrique Alves Rocha
// Data atual  : 14/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   agenciaBancaria,contaBancaria, senhaBancaria:inteiro
   opcaoPrincipal,opcaoTipoDeposito, agenciaBancariaDeposito:inteiro
   contaBancariaDeposito,valorDeposito: inteiro
Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   repita
      Escreval("-------------------------------------------")
      Escreval("-----------SISTEMA BANCÁRIO BADL-----------")
      Escreval("-------------------------------------------")
      Escreval("")
      Escreval("")
      Escreval("")
      Escreval("Digite a sua agęncia bancária :")
      Leia(agenciaBancaria)
      Escreval("Digite a sua conta :")
      Leia(contaBancaria)
      Escreval("Digite a sua senha :")
      Leia(senhaBancaria)
      se (agenciaBancaria = 1234) e (contaBancaria =4321) e (senhaBancaria = 123456) entăo
         Escreval("Acesso Permitido")
         tempo 400
         limpatela
         Escreval("-------------------------------------------")
         Escreval("--SEJA BEM VINDO AO SISTEMA BANCÁRIO BADL--")
         Escreval("-------------------------------------------")
         Escreval("")
         Escreval("SELECIONE A OPÇĂO DESEJADA  A SEGUIR:")
         Escreval("")
         Escreval("1 - DEPÓSITO")
         Escreval("2 - SAQUE")
         Escreval("3 - TRANSFERĘNCIA")
         Escreval("4 - CARTŐES")
         Escreval("5 - SALDO")
         Escreval("6 - PIX")
         Escreval("7 - EXTRATO")
         Escreval("8 - EMPRÉSTIMO")
         Escreval("")
         Escreval("Digite aqui sua opçăo :")
         Leia (opcaoPrincipal)
         limpatela

         Escolha opcaoPrincipal

         caso 1
            Escreval("-------------------------------------------")
            Escreval("--SEJA BEM VINDO AO SISTEMA BANCÁRIO BADL--")
            Escreval("-------------------------------------------")
            Escreval("")
            Escreval("VOCĘ SELECIONOU A OPÇĂO :")
            Escreval("1 - DEPÓSITO")
            Escreval("")
            Escreval("SELECIONE O TIPO DE DEPOSITO A SEGUIR:")
            Escreval("")
            Escreval("1 - DINHEIRO")
            Escreval("2 - CHEQUE")
            Escreval("")
            Leia(opcaoTipoDeposito)
            Escreval("")
            Escreval("Digite a agęncia bancária do destinatário:")
            Leia(agenciaBancariaDeposito)
            Escreval("Digite a conta bancária do destinatário:")
            Leia(contaBancariaDeposito)
            Escreval("Digite o valor a ser depositado:")
            Leia(valorDeposito)
         senao
            Escreval("Acesso Negado")
            tempo 600
            limpatela
         fimse
      até (agenciaBancaria = 1234) e (contaBancaria =4321) e (senhaBancaria = 123456)


Fimalgoritmo