Algoritmo "Soma"
// Disciplina   : [Lógica de Programaçăo]
// Professor   : Jailson
// Descriçăo   : Solicita dois números para o usuário, soma e exibe o resultado
// Autor(a)    : Gabriel Henrique Alves Rocha
// Data atual  : 26/03/2026
Var
nome:caractere
sobrenome:caractere
nomecompleto:caractere

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("Digite seu nome ")
leia(nome)
escreva("Digite seu sobrenome ")
leia(sobrenome)
nomecompleto <- nome + " " + sobrenome
escreva("Olá ", nomecompleto)
Fimalgoritmo