Algoritmo "Sucessor"
// Disciplina   : [Lógica de Programaçăo]
// Professor   : Jailson
// Descriçăo   : Solicita dois números para o usuário, soma e exibe o resultado
// Autor(a)    : Gabriel Henrique Alves Rocha
// Data atual  : 26/03/2026
Var
numero01:real
resultado:real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("Digite um número ")
leia(numero01)
resultado <- numero01 + 1
escreva("resultado", resultado)
Fimalgoritmo